---
import BaseLayout from './BaseLayout.astro';
import RelatedArticles from '../components/RelatedArticles.astro';

interface FaqItem {
    question: string;
    answer: string;
}

interface Props {
    title: string;
    description: string;
    keywords: string;
    coverImage: string;
    coverAlt: string;
    datePublished: string;
    dateModified: string;
    excerpt: string;
    tags: string[];
    slug: string;
    category: string;
    faq?: FaqItem[];
}

const { title, description, keywords, coverImage, coverAlt, datePublished, dateModified, excerpt, tags, slug, category, faq } = Astro.props;
const coverImageURL = new URL(coverImage, Astro.site).href;

const articleSchema = {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "image": coverImageURL,
    "inLanguage": "ar",
    "author": { "@type": "Organization", "name": "تربية بلس", "url": "https://www.tarbiyaplus.com" },
    "publisher": { "@type": "Organization", "name": "تربية بلس", "url": "https://www.tarbiyaplus.com" },
    "datePublished": datePublished,
    "dateModified": dateModified,
    "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": new URL(`/articles/${slug}/`, Astro.site).href,
    },
};

const breadcrumbSchema = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
        {
            "@type": "ListItem",
            "position": 1,
            "name": "الرئيسية",
            "item": new URL("/", Astro.site).href,
        },
        {
            "@type": "ListItem",
            "position": 2,
            "name": "المقالات",
            "item": new URL("/articles/", Astro.site).href,
        },
        {
            "@type": "ListItem",
            "position": 3,
            "name": category,
            "item": new URL(`/articles/category/${encodeURIComponent(category)}/`, Astro.site).href,
        },
        {
            "@type": "ListItem",
            "position": 4,
            "name": title,
        },
    ],
};

const faqSchema = faq && faq.length > 0 ? {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faq.map(item => ({
        "@type": "Question",
        "name": item.question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": item.answer,
        },
    })),
} : null;
---
<BaseLayout title={`${title} | تربية بلس`} description={description} ogType="article" canonicalPath={`/articles/${slug}/`} ogImage={coverImage}>
    <Fragment slot="head">
        <meta name="keywords" content={keywords}>
        <meta property="article:published_time" content={datePublished}>
        <meta property="article:modified_time" content={dateModified}>
        <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
        <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
        {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
    </Fragment>

    <main class="article-container">
        <nav class="breadcrumbs" aria-label="مسار التصفح">
            <a href="/">الرئيسية</a>
            <span class="breadcrumb-sep">/</span>
            <a href="/articles/">المقالات</a>
            <span class="breadcrumb-sep">/</span>
            <a href={`/articles/category/${encodeURIComponent(category)}/`}>{category}</a>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-current">{title}</span>
        </nav>

        <article>
            <h1>{title}</h1>
            <img src={coverImage} alt={coverAlt} class="article-cover" loading="eager">

            <div class="article-intro">
                <p>{excerpt}</p>
            </div>

            <slot />

            <RelatedArticles currentSlug={slug} tags={tags} />
        </article>
    </main>
</BaseLayout>
