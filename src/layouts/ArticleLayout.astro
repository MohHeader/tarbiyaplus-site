---
import BaseLayout from './BaseLayout.astro';
import RelatedArticles from '../components/RelatedArticles.astro';

interface Props {
    title: string;
    description: string;
    keywords: string;
    coverImage: string;
    coverAlt: string;
    datePublished: string;
    dateModified: string;
    excerpt: string;
    tags: string[];
    slug: string;
}

const { title, description, keywords, coverImage, coverAlt, datePublished, dateModified, excerpt, tags, slug } = Astro.props;
const schemaOrg = {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "inLanguage": "ar",
    "author": { "@type": "Organization", "name": "تربية بلس" },
    "publisher": { "@type": "Organization", "name": "تربية بلس" },
    "datePublished": datePublished,
    "dateModified": dateModified,
};
---
<BaseLayout title={`${title} | تربية بلس`} description={description} ogType="article" canonicalPath={`/articles/${slug}/`}>
    <Fragment slot="head">
        <meta name="keywords" content={keywords}>
        <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />
    </Fragment>

    <main class="article-container">
        <article>
            <h1>{title}</h1>
            <img src={coverImage} alt={coverAlt} class="article-cover">

            <div class="article-intro">
                <p>{excerpt}</p>
            </div>

            <slot />

            <RelatedArticles currentSlug={slug} tags={tags} />
        </article>
    </main>
</BaseLayout>
